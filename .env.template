# Environment Variables Template
# Copy this file to .env.local and fill in your values

# ===== Database =====
DB_NAME=listing_db
DB_USER=admin
DB_PASSWORD=postgres
DATABASE_URL=postgresql://admin:postgres@localhost:5432/listing_db
DIRECT_URL=postgresql://admin:postgres@localhost:5432/listing_db

# ===== API Configuration =====
NODE_ENV=development
TARGET_URL=http://localhost:4000
API_GATEWAY_URL=http://localhost:8080

# ===== Rate Limiting =====
GATEWAY_RATE_LIMIT=3

# ===== LLM Configuration =====
# Choose: openai or ollama
LLM_PROVIDER=openai

# For OpenAI
OPENAI_API_KEY=sk-...  # Get from https://platform.openai.com/api-keys
OPENAI_MODEL=gpt-3.5-turbo

# For Ollama (local)
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# ===== Firebase Configuration =====
# Get from Firebase Console → Service Account
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n....\n-----END PRIVATE KEY-----\n
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project.iam.gserviceaccount.com

# ===== Frontend Configuration =====
FRONTEND_URL=http://localhost:3000
VITE_BACKEND_URL=http://localhost:5000
